# Используем лёгкий образ Node.js (Alpine)
FROM node:20-alpine

# Рабочая директория внутри контейнера
WORKDIR /app

# Копируем файлы зависимостей для кэширования слоя
COPY package*.json ./

# Устанавливаем зависимости (используем ci для чистоты)
RUN npm ci

# Копируем остальные файлы проекта
# (некоторые папки будут перезаписаны volumes, но index.html, vite.config.js и т.д. нужны)
COPY . .

# Порт, который слушает Vite внутри контейнера
EXPOSE 3000

# Запускаем dev-сервер Vite с явным указанием хоста и порта
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]